<section class="policy-hero">
  <div class="container">
    <span class="eyebrow">Help</span>
    <h1>Frequently Asked Questions</h1>
  </div>
</section>

<section class="policy-body">
  <div class="container">
    <div class="policy-text">
      {%- for block in section.blocks -%}
        {%- if block.type == 'heading' -%}
          {%- if forloop.index > 1 -%}<hr>{%- endif -%}
          <h2 {% if block.settings.anchor != blank %}id="{{ block.settings.anchor }}"{% endif %} {{ block.shopify_attributes }}>{{ block.settings.text }}</h2>
        {%- elsif block.type == 'question' -%}
          <details class="faq-item" {{ block.shopify_attributes }} {% if block.settings.open %}open{% endif %}>
            <summary>{{ block.settings.question }}</summary>
            <p>{{ block.settings.answer }}</p>
          </details>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ Page",
  "settings": [],
  "blocks": [
    {
      "type": "heading",
      "name": "Section heading",
      "settings": [
        { "type": "text", "id": "text",   "label": "Heading text", "default": "Orders & Shipping" },
        { "type": "text", "id": "anchor", "label": "Anchor ID (optional)" }
      ]
    },
    {
      "type": "question",
      "name": "FAQ item",
      "settings": [
        { "type": "text",     "id": "question", "label": "Question" },
        { "type": "textarea", "id": "answer",   "label": "Answer" },
        { "type": "checkbox", "id": "open",     "label": "Open by default", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Page",
      "blocks": [
        { "type": "heading",  "settings": { "text": "Orders & Shipping" } },
        { "type": "question", "settings": { "question": "How long does shipping take?", "answer": "Every order is packed by hand from South Carolina. Processing takes 1-2 business days, and standard shipping is 3-5 business days after that. You'll get a tracking email as soon as it ships.", "open": true } },
        { "type": "question", "settings": { "question": "Do you offer free shipping?", "answer": "Yes! Free standard shipping on all orders $75 and up. No code needed -- it applies automatically at checkout." } },
        { "type": "question", "settings": { "question": "Can I change or cancel my order?", "answer": "We start packing pretty quickly, but if you catch us in time we'll do our best. Email support@coastalpalm.shop as soon as possible and we'll see what we can do." } },
        { "type": "heading",  "settings": { "text": "Returns & Exchanges" } },
        { "type": "question", "settings": { "question": "What's your return policy?", "answer": "30 days from delivery. Items must be unworn, unwashed, with tags still attached. Returns are issued as store credit." } },
        { "type": "question", "settings": { "question": "Can I exchange for a different size?", "answer": "Absolutely! Email us at support@coastalpalm.shop with your order number and we'll swap it out (subject to availability)." } },
        { "type": "question", "settings": { "question": "What are Final Sale items?", "answer": "Items marked Final Sale on the product page can't be returned or exchanged. We always mark these clearly before you buy." } },
        { "type": "heading",  "settings": { "text": "AI Try-On", "anchor": "tryon-faq" } },
        { "type": "question", "settings": { "question": "What is AI Try-On?", "answer": "It's our virtual fitting room. Upload a photo of yourself and our AI shows you exactly how a piece will look on your body -- before you buy. No more guessing." } },
        { "type": "question", "settings": { "question": "Is my photo saved?", "answer": "No. Your photo is processed in real-time and never stored on our servers. We take your privacy seriously -- your image is used only for the try-on and immediately discarded." } },
        { "type": "question", "settings": { "question": "What kind of photo works best?", "answer": "A full-body or head-to-knees photo works best. Stand facing the camera, use good lighting, and keep the background simple. Phone photos are perfect." } },
        { "type": "question", "settings": { "question": "How accurate is it?", "answer": "It's powered by advanced AI that understands how fabric drapes on different body types. It's not a Photoshop cutout -- it genuinely simulates how the garment fits. Most customers say it's surprisingly close to real life." } },
        { "type": "heading",  "settings": { "text": "Sizing" } },
        { "type": "question", "settings": { "question": "How do your clothes fit?", "answer": "Most of our pieces run true to size with a relaxed, beachy fit. If you're between sizes, size down for fitted or stay true for breezier." } },
        { "type": "question", "settings": { "question": "Do you have plus sizes?", "answer": "We currently carry XS through 2X in most styles. We're always working to expand our size range -- stay tuned." } },
        { "type": "heading",  "settings": { "text": "Other Questions" } },
        { "type": "question", "settings": { "question": "Where are you based?", "answer": "South Carolina! Every order is packed with love right here at home." } },
        { "type": "question", "settings": { "question": "How can I contact you?", "answer": "Email us anytime at support@coastalpalm.shop -- we get back to you within 24 hours. You can also DM us on Instagram." } }
      ]
    }
  ]
}
{% endschema %}
