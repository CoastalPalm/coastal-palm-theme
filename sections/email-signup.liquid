<section class="email-signup">
  <div class="container">
    <span class="eyebrow" style="color: #F09DAE;">{{ section.settings.eyebrow }}</span>
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.body }}</p>
    {%- form 'customer', class: 'email-signup-form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input type="email" name="contact[email]" placeholder="your@email.com" required>
      <button type="submit">Join Now</button>
    {%- endform -%}
    <div class="perks">
      {%- for block in section.blocks -%}
        <span {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Email Signup",
  "settings": [
    { "type": "text",     "id": "eyebrow", "label": "Eyebrow", "default": "Join the Palm List" },
    { "type": "text",     "id": "heading",  "label": "Heading",  "default": "Be the first to know." },
    { "type": "textarea", "id": "body",     "label": "Body",     "default": "New arrivals, exclusive drops, and 10% off your first order. No spam, just sun-soaked style delivered to your inbox." }
  ],
  "blocks": [
    {
      "type": "perk",
      "name": "Perk",
      "settings": [
        { "type": "text", "id": "text", "label": "Perk text", "default": "10% off first order" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Email Signup",
      "blocks": [
        { "type": "perk", "settings": { "text": "✨ 10% off first order" } },
        { "type": "perk", "settings": { "text": "🌴 Early access to drops" } },
        { "type": "perk", "settings": { "text": "💌 Curated style tips" } }
      ]
    }
  ]
}
{% endschema %}
