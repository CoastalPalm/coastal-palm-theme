<section style="padding: 80px 0;">
  <div class="container" style="max-width: 880px;">
    <span class="eyebrow">Your bag</span>
    <h1 style="margin: 12px 0 32px;">{% if cart.item_count > 0 %}{{ cart.item_count }} {{ cart.item_count | pluralize: 'piece', 'pieces' }}{% else %}Your bag is empty{% endif %}</h1>

    {%- if cart.item_count > 0 -%}
      {%- form 'cart', cart -%}
        <div style="display: flex; flex-direction: column; gap: 20px; margin-bottom: 32px;">
          {%- for item in cart.items -%}
            <div style="display: grid; grid-template-columns: 100px 1fr auto; gap: 20px; align-items: center; padding: 20px; background: white; border-radius: var(--r-md);">
              <a href="{{ item.url }}"><img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title | escape }}" width="100" height="125" style="width: 100%; height: auto; border-radius: var(--r-sm);" loading="lazy" decoding="async"></a>
              <div>
                <a href="{{ item.url }}" style="font-weight: 500; color: var(--ink);">{{ item.product.title }}</a>
                {%- unless item.product.has_only_default_variant -%}
                  <div style="font-size: 0.85rem; color: var(--ink-soft);">{{ item.variant.title }}</div>
                {%- endunless -%}
                <div style="margin-top: 8px;">
                  <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" style="width: 64px; padding: 6px 10px; border: 1px solid var(--line); border-radius: var(--r-sm);">
                </div>
              </div>
              <div style="text-align: right;">
                <div style="font-weight: 600;">{{ item.final_line_price | money }}</div>
                <a href="{{ item.url_to_remove }}" style="font-size: 0.78rem; color: var(--ink-soft); margin-top: 6px; display: inline-block;">Remove</a>
              </div>
            </div>
          {%- endfor -%}
        </div>

        <div style="display: flex; justify-content: space-between; align-items: center; padding: 24px; background: var(--sand); border-radius: var(--r-md); margin-bottom: 16px;">
          <span style="font-family: var(--font-display); font-size: 1.4rem;">Subtotal</span>
          <span style="font-family: var(--font-display); font-size: 1.4rem;">{{ cart.total_price | money }}</span>
        </div>

        <div style="display: flex; gap: 12px; flex-wrap: wrap;">
          <button type="submit" name="update" class="btn btn-outline">Update bag</button>
          <button type="submit" name="checkout" class="btn btn-primary" style="flex: 1;">Check out — {{ cart.total_price | money }}</button>
        </div>
      {%- endform -%}
    {%- else -%}
      <p style="color: var(--ink-soft); margin-bottom: 24px;">Nothing here yet. Find something you love.</p>
      <a href="{{ routes.all_products_collection_url }}" class="btn btn-primary">Shop the catalog</a>
    {%- endif -%}
  </div>
</section>
